{
    "name": "dencel/iris-screen",
    "type": "project",
    "description": "Self-hosted digital signage manager.",
    "keywords": [
        "digital-signage",
        "screens",
        "slideshow",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "filament/filament": "^5.0",
        "intervention/image": "^4.0",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.5",
        "fakerphp/faker": "^1.9.1",
        "larastan/larastan": "^3.10",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.4",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "vendor/bin/phpunit",
        "analyse": "php -d phar.readonly=0 vendor/bin/phpstan analyse --no-progress",
        "lint": "vendor/bin/pint --test",
        "rector": "vendor/bin/rector --no-progress-bar --dry-run",
        "deploy-latest": [
            "php artisan down",
            "git reset --hard HEAD",
            "git clean -fd",
            "git pull origin master",
            "composer install --no-dev --optimize-autoloader",
            "npm install",
            "npm run build",
            "php artisan migrate --force",
            "php artisan storage:link --relative",
            "php artisan icons:cache",
            "php artisan optimize",
            "php artisan filament:optimize",
            "php artisan queue:restart",
            "php artisan up"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
